207: Course schedule
class Solution {
public:
    bool canFinish(int numCourses, vector<vector<int>>& prerequisites) {
      vector<vector<int>>graph(numCourses);
      for(auto i:prerequisites){
        graph[i[0]].push_back(i[1]);
      }   

      vector<int>in(numCourses,0);
      for(auto i:prerequisites){
        in[i[1]]++;
      }   
      queue<int>q;
      vector<int>ans;
      for(int i=0; i<numCourses; i++){
            if(in[i] == 0){
                q.push(i);
            }
        }
        while(!q.empty()){
            int curr = q.front();
            q.pop();
            ans.push_back(curr);

            for(int i=0; i<graph[curr].size(); i++){
                in[graph[curr][i]]--;
                if(in[graph[curr][i]] == 0) 
                    q.push(graph[curr][i]);            
            }
        }
      
      if(ans.size() == numCourses) 
      return true;

      return false;
    }
};

DYNAMIC PROGRAMMING
509: fibonnaci series
class Solution {
public:
   
    int helper(int n, vector<int>& dp){
        if(n == 1|| n== 0) return n;

        if(dp[n] == 0){
            dp[n] = helper(n-1, dp) + helper(n-2, dp);
        }
        return dp[n];
    }  

    int fib(int n) {
       vector<int>dp(n+1,0);

       return helper(n,dp);
    }
};
