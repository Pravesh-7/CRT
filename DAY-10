108: sorted array to binary search

class Solution {
public:

    TreeNode* createTree(vector<int>& nums, int st, int end){
        if(st>end) return NULL;
        int mid = st+(end-st)/2;

        TreeNode* root = new TreeNode(nums[mid]);

        root->left = createTree(nums, st, mid-1);
        root->right = createTree(nums, mid+1, end);

        return root;
    } 

    TreeNode* sortedArrayToBST(vector<int>& nums) {

        return createTree(nums, 0, nums.size()-1);

    }
};

109: sorted list to  BST
class Solution {
public:
     TreeNode* createTree(vector<int>& vec, int st, int end){
        if(st>end) return NULL;
        int mid = st+(end-st)/2;

        TreeNode* root = new TreeNode(vec[mid]);

        root->left = createTree(vec, st, mid-1);
        root->right = createTree(vec, mid+1, end);

        return root;
    } 

    TreeNode* sortedListToBST(ListNode* head) {
     ListNode* temp = head;
     vector<int>vec;

     while(temp != NULL){
        vec.push_back(temp->val);
        temp = temp->next;
     } 

     return createTree(vec, 0, vec.size()-1);

    }
};

96: unique bsts
class Solution {
public:

    int numTrees(int n) {
       long long ans=1;
       for(int i=0; i<n; i++){
          ans *= 2*n-i;
          ans = ans/(i+1);
       }
      
        return ans/(n+1);
    }
};

98: validate BST
class Solution {
public:
   bool helper(TreeNode* root, long min, long max){
    if(root == NULL) return true;
     if(root->val <= min || root->val >= max){
        return false;
     }

     return helper(root->left, min, root->val) && helper(root->right, root->val, max);

   }

    bool isValidBST(TreeNode* root) {
        return helper(root, LONG_MIN, LONG_MAX);
    }
};

Bottom view of tree
class Solution {
  public:
    vector<int> bottomView(Node *root) {
        // code here
        vector<int>ans;
        if(root == NULL){
            return {};
        }
       
        queue<pair<Node*,int>>q; // storing node and it's horizontal distance
        
        map<int,int>m;//(horizontal dis,node val)
        
        q.push({root,0});
        
        while(q.size() > 0){
            Node* curr = q.front().first;
            int  currHD = q.front().second;
            q.pop();
            
         
                m[currHD] = curr->data;
            
            if(curr->left != NULL){
                q.push({curr->left, currHD-1});
            }
            
            if(curr->right != NULL){
                q.push({curr->right, currHD+1});
            }
        }
        
        
        for(auto it:m){
            ans.push_back(it.second);
        }
        
       return ans;
    }
};


