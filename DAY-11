105: construct binary tree from preorder and inorder
class Solution {
    TreeNode* buildTree(unordered_map<int, int>&m, vector<int>& inorder, int inSt, int inEnd, vector<int>& preorder,int preSt, int preEnd){
        if(preSt > preEnd || inSt > inEnd) return NULL;

        TreeNode* root = new TreeNode(preorder[preSt]);
        int rootIdx = m[root->val];
        int leftSize = rootIdx-inSt;
        root->left = buildTree(m, inorder, inSt, rootIdx-1, preorder, preSt+1, preSt+leftSize);
        root->right = buildTree(m, inorder, rootIdx+1, inEnd,  preorder, preSt+leftSize+1, preEnd);

        return root;

    }
public:
    TreeNode* buildTree(vector<int>& preorder, vector<int>& inorder) {
       unordered_map<int,int>m;
       
       for(int i=0; i<inorder.size(); i++){
        m[inorder[i]] = i;
       }
        return buildTree(m, inorder,0, inorder.size()-1, preorder, 0, preorder.size()-1);
    }
};
