class Solution {
  public:
    vector<int> nextLargerElement(vector<int>& arr) {
        // code here
      int n = arr.size();
      stack<int>s;
      vector<int>ans(n,0);
      
      for(int i=n-1; i>=0; i--){
          while(s.size()>0 &&  s.top() <= arr[i]){
              s.pop();
          }
          
          if(s.empty()) ans[i] = -1;
          
          else{
              ans[i] = s.top();
          }
          
          s.push(arr[i]);
      }
      return ans;
        
    }
};

